# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# ─── Anthropic (server-side only) ────────────────────────────────────────────
# Used exclusively inside the Supabase Edge Function `generate-build`.
# NEVER prefix this with VITE_ — it must not be exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Gemini fallback (server-side only) ──────────────────────────────────────
# Used by the `generate-build` Edge Function when Claude is unavailable.
# NEVER prefix with VITE_.
GEMINI_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
# Desktop builds run under the Tauri custom scheme (tauri://localhost on macOS,
# http://tauri.localhost on Windows), so auth redirect URLs are not used.
# Left here only for `npm run dev` in a browser during UI work.
VITE_APP_URL=http://localhost:1420
