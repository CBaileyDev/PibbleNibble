# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Anthropic (server-side only) ────────────────────────────────────────────
# Used exclusively inside the Supabase Edge Function `generate-build`.
# NEVER prefix this with VITE_ — it must not be exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL used for Supabase Auth redirect callbacks.
VITE_APP_URL=http://localhost:5173
