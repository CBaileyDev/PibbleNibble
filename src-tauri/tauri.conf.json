{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pibble & Nibble",
  "version": "0.1.0",
  "identifier": "com.pibblenibble.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pibble & Nibble",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https://*.supabase.co wss://*.supabase.co; script-src 'self'; frame-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "category": "Utility",
    "copyright": "© 2026 Pibble & Nibble",
    "shortDescription": "Minecraft companion for two — AI build design, tracking, notes.",
    "longDescription": "Pibble & Nibble is a private Minecraft companion app: AI-powered build design, project tracking, and shared world notes. Desktop-only, synced via Supabase.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "allowDowngrades": true,
      "wix": { "language": "en-US" },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}
